                "showHeader": true
            },
            "pluginVersion": "9.0.0",
            "targets": [
                {
                    "format": "time_series",
                    "rawSql": "SELECT service_name, metric_name, max(latency_ms) as max_latency_ms, quantile(0.95)(latency_ms) as p95_ms, quantile(0.5)(latency_ms) as p50_ms, count() as samples FROM telemetry.pipeline_latencies WHERE timestamp >= now() - INTERVAL 1 HOUR GROUP BY service_name, metric_name ORDER BY max_latency_ms DESC",
                    "refId": "A"
                }
            ],
            "title": "Max/P95/P50 Latencies (Last Hour)",
            "type": "table"
