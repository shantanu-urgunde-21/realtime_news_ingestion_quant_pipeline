            },
            "pluginVersion": "9.0.0",
            "targets": [
                {
                    "format": "time_series",
                    "rawSql": "SELECT toStartOfMinute(timestamp) as time, concat(service_name, ' - ', metric_name) as label, quantile(0.5)(latency_ms) as p50, quantile(0.95)(latency_ms) as p95, quantile(0.99)(latency_ms) as p99 FROM telemetry.pipeline_latencies WHERE timestamp >= now() - INTERVAL 6 HOUR GROUP BY time, service_name, metric_name ORDER BY time ASC",
                    "refId": "A"
                }
            ],
            "title": "Latency Percentiles (P50, P95, P99) - 6 Hour Window",
            "type": "timeseries"
        },
